whiteningTVAR <- function(x, maxlag, returnSS) {
# center
x <- scale(x, T,F)
# Whitening matrix
whiteMatrix <- residual_tvAR(x, maxlag = mlag, returnWhite = T)
# Whitening
x <- x%*%whiteMatrix
if (!returnSS) return(x)
apply(x, 1,\(x){sum(x^2)})
}
whiteningTVAR(x)

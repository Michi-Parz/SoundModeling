uncertainty_smoothing(1:10, 1:10, 3.1, 0.4)
uncertainty_smoothing(1:10, 1:10, 1, 0.4)
uncertainty_smoothing(1:10, 1:10, 2, 0.4)
uncertainty_smoothing(1:10, 1:10, 9, 0.4)
uncertainty_smoothing(1:10, 1:10, 10, 0.4)
uncertainty_smoothing(1:10, 1:10, 3, 0.4)
debugonce(uncertainty_smoothing)
